{
  "name": "open-order",
  "version": "0.1.0",
  "private": true,
  "description": "Open Order — evidence-first procedural retrieval for New Zealand parliamentary material.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint",
    "db:check": "node --env-file=.env.local --import tsx scripts/db-check.ts",
    "db:apply": "node --env-file=.env.local --import tsx scripts/apply-sql.ts",
    "db:inspect": "node --env-file=.env.local --import tsx scripts/db-inspect.ts",
    "db:seed-documents": "node --env-file=.env.local --import tsx scripts/seed-documents.ts",
    "db:list-documents": "node --env-file=.env.local --import tsx scripts/list-documents.ts",
    "db:ingest-speakers-rulings": "node --env-file=.env.local --import tsx scripts/ingest-speakers-rulings.ts",
    "db:count-sections": "node --env-file=.env.local --import tsx scripts/count-sections.ts",
    "db:sample-sections": "node --env-file=.env.local --import tsx scripts/sample-sections.ts",
    "db:heading-stats": "node --env-file=.env.local --import tsx scripts/heading-stats.ts",
    "db:chapter-stats": "node --env-file=.env.local --import tsx scripts/chapter-stats.ts",
    "db:null-heading-samples": "node --env-file=.env.local --import tsx scripts/null-heading-samples.ts",
    "db:tail-sections": "node --env-file=.env.local --import tsx scripts/tail-sections.ts",
    "db:ingest-speakers-rulings-html": "node --env-file=.env.local --import tsx scripts/ingest-speakers-rulings-html.ts",
    "db:ingest-standing-orders-html": "node --env-file=.env.local --import tsx scripts/ingest-standing-orders-html.ts",
    "db:chunk-sections": "node --env-file=.env.local --import tsx scripts/chunk-sections.ts",
    "db:count-chunks": "node --env-file=.env.local --import tsx scripts/count-chunks.ts"
  },
  "dependencies": {
    "@google/genai": "^1.48.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "next": "^16.2.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.12.0",
    "playwright": "^1.59.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.14.0",
    "eslint-config-next": "^16.2.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
